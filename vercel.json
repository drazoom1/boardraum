{
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/post/(.*)", "destination": "/api/render?type=post&id=$1" },
    { "source": "/game/(.*)", "destination": "/api/render?type=game&slug=$1" },
    { "source": "/((?!.*\\.pdf$).*)", "destination": "/index.html" }
  ]
}
